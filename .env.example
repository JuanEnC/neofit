# NeoFit — Environment Variables Reference
#
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
#
# Values marked [CDK output] are printed after running: cdk deploy --context environment=dev
# Values marked [SSM] are stored in AWS SSM Parameter Store and injected at runtime.

# ─── AWS ──────────────────────────────────────────────────────────────────────

AWS_REGION=us-east-1
AWS_ACCOUNT_ID=                         # 12-digit account ID

# ─── ENVIRONMENT ──────────────────────────────────────────────────────────────

# "development" | "production"
ENVIRONMENT=development
NODE_ENV=development

# ─── COGNITO ──────────────────────────────────────────────────────────────────
# [CDK output: CognitoUserPoolId / CognitoClientId]

COGNITO_USER_POOL_ID=                   # e.g. us-east-1_RnRmhnJHC
COGNITO_CLIENT_ID=                      # e.g. 1np05krkcq7ui76t67o2i6v41d

# ─── API GATEWAY ──────────────────────────────────────────────────────────────
# [CDK output: ApiGatewayUrl]

API_GATEWAY_URL=                        # e.g. https://iw6b9t7fbj.execute-api.us-east-1.amazonaws.com

# ─── DYNAMODB ─────────────────────────────────────────────────────────────────
# [CDK output: DynamoDbTableName]

DYNAMODB_TABLE_NAME=NeoFit_MasterTable_dev

# ─── S3 ───────────────────────────────────────────────────────────────────────
# [CDK output: S3BucketName]

S3_BUCKET_NAME=                         # e.g. neofit-frontend-dev-177922194578

# ─── SQS ──────────────────────────────────────────────────────────────────────
# [CDK output: NotificationQueueUrl]

NOTIFICATION_QUEUE_URL=                 # e.g. https://sqs.us-east-1.amazonaws.com/...
DLQ_URL=                                # e.g. https://sqs.us-east-1.amazonaws.com/...

# ─── STRIPE ───────────────────────────────────────────────────────────────────
# [SSM] — stored in /neofit/stripe/secret-key at runtime
# Only needed locally for running backend tests against Stripe sandbox.

STRIPE_SECRET_KEY=sk_test_              # never use live keys in development
STRIPE_WEBHOOK_SECRET=whsec_           # from Stripe Dashboard > Webhooks > Signing secret

# ─── FRONTEND (NEXT.JS PUBLIC VARIABLES) ─────────────────────────────────────
# Prefix NEXT_PUBLIC_ exposes these to the browser bundle.

NEXT_PUBLIC_API_BASE_URL=               # same as API_GATEWAY_URL above
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=       # same as COGNITO_USER_POOL_ID above
NEXT_PUBLIC_COGNITO_CLIENT_ID=          # same as COGNITO_CLIENT_ID above
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
NEXT_PUBLIC_ENVIRONMENT=development

# ─── CDK / INFRASTRUCTURE ─────────────────────────────────────────────────────

CDK_DEFAULT_ACCOUNT=                    # same as AWS_ACCOUNT_ID
CDK_DEFAULT_REGION=us-east-1
