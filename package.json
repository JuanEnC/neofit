{
  "name": "neofit",
  "version": "1.0.0",
  "description": "Gym Management System SaaS MVP - Serverless Stack",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "lint": "eslint infrastructure/lib infrastructure/bin backend/src --ext .ts --max-warnings 0",
    "format": "prettier --write . --ignore-path .prettierignore",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "build": "pnpm --filter neofit-infrastructure build",
    "test:unit": "echo 'Tests will be added in Phase 2' && exit 0",
    "deploy:infra": "bash scripts/deploy-infrastructure.sh dev us-east-1"
  },
  "keywords": [
    "gym",
    "fitness",
    "saas",
    "serverless",
    "aws",
    "nextjs"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0"
  }
}
