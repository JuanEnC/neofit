{
  "name": "neofit",
  "version": "1.0.0",
  "description": "Gym Management System SaaS MVP - Serverless Stack",
  "private": true,
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": ["unrs-resolver"]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "lint": "eslint infrastructure/lib infrastructure/bin backend/src --ext .ts --max-warnings 0",
    "format": "prettier --write . --ignore-path .prettierignore",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "build": "pnpm --filter neofit-infrastructure build",
    "test:unit": "echo 'Tests will be added in Phase 2' && exit 0",
    "deploy:infra": "bash scripts/deploy-infrastructure.sh dev us-east-1",
    "seed": "pnpm --filter neofit-backend seed",
    "seed:local": "pnpm --filter neofit-backend seed:local",
    "db:local:start": "docker compose up -d dynamodb-local",
    "db:local:stop": "docker compose down",
    "db:local:setup": "bash scripts/setup-local-dynamo.sh"
  },
  "keywords": [
    "gym",
    "fitness",
    "saas",
    "serverless",
    "aws",
    "nextjs"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0"
  }
}
